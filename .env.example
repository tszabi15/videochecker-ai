# Gemini API Key for video analysis
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key for Whisper transcription (if WHISPER_BACKEND=api)
OPENAI_API_KEY=your-openai-api-key-here

# Google Cloud Storage Settings
GCS_BUCKET_NAME=videochecker-ai-bucket
GCS_PROJECT_ID=videochecker-ai-project

# Database & Cache URLs (Docker compose network default)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/videochecker
REDIS_URL=redis://redis:6379/0

# Whisper Backend: "api" (OpenAI Audio API) or "local" (openai-whisper library)
WHISPER_BACKEND=api

# Max video file upload size in MB
MAX_VIDEO_SIZE_MB=2048

# Default AI model for analysis
DEFAULT_MODEL=gemini-3.1-pro
